{
  "$schema": "https://aora.schema.json",
  "name": "AORA - OpenCode Agents Runtime",
  "version": "1.1.0",
  "language": "es",

  "global": {
    "description": "Configuración global para todos los agentes",
    "baseModel": "minimax/MiniMax-M2.7",
    "temperature": 0.3,
    "mode": "primary"
  },

  "caveman": {
    "enabled": true,
    "global": {
      "enabled": false,
      "model": "full"
    },
    "levels": {
      "lite": {
        "description": "Sin filler, gramática intacta, profesional sin fluff",
        "rules": ["drop_filler", "keep_grammar", "no_pleasantries"]
      },
      "full": {
        "description": "Sin artículos, fragmentos OK, grunt completo",
        "rules": ["no_articles", "fragments_ok", "drop_hedging", "short_synonyms"]
      },
      "ultra": {
        "description": "Máxima compresión. Telegráfico. Abreviar todo.",
        "rules": ["maximum_compression", "telegraphic", "abbreviate", "single_words"]
      },
      "none": {
        "description": "No usar caveman",
        "rules": []
      }
    },
    "activation": ["caveman", "compact", "modoahorro", "ahorrar"]
  },

  "models": {
    "base": {
      "id": "minimax/MiniMax-M2.7",
      "name": "MiniMax-M2.7",
      "description": "Modelo base para tareas complejas de razonamiento",
      "contextWindow": 100000,
      "strengths": ["codificación", "razonamiento complejo", "multi-step"]
    },
    "fast": {
      "id": "minimax/MiniMax-M2.7",
      "name": "MiniMax-M2.7 Fast",
      "description": "Variante optimizada para tareas de baja latencia",
      "contextWindow": 100000,
      "strengths": ["documentación", "búsqueda", "tareas rápidas"]
    },
    "coder": {
      "id": "minimax/MiniMax-M2.7",
      "name": "MiniMax-M2.7 Coder",
      "description": "Especializado para implementación y debugging",
      "contextWindow": 100000,
      "strengths": ["implementación", "debug", "caveman-debug"]
    },
    "review": {
      "id": "minimax/MiniMax-M2.7",
      "name": "MiniMax-M2.7 Review",
      "description": "Optimizado para análisis y revisión de código",
      "contextWindow": 100000,
      "strengths": ["análisis", "seguridad", "patrones"]
    }
  },

  "agents": {
    "ultraworker": {
      "description": "Orquestador de ciclo completo",
      "model": "base",
      "temperature": 0.2,
      "compact": false,
      "cavemanLevel": "full",
      "permissions": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "allow"
      },
      "activation": ["ultrawork", "ulw"],
      "semantic": "OrquestadorPrincipal"
    },
    "planner": {
      "description": "Arquitecto estratégico - planificación y descomposición",
      "model": "base",
      "temperature": 0.3,
      "compact": false,
      "cavemanLevel": "lite",
      "permissions": {
        "read": "allow",
        "edit": "deny",
        "bash": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow"
      },
      "semantic": "Estratega"
    },
    "builder": {
      "description": "Implementador full-stack - código y ejecución",
      "model": "coder",
      "temperature": 0.2,
      "compact": false,
      "cavemanLevel": "full",
      "permissions": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow"
      },
      "semantic": "Constructor"
    },
    "reviewer": {
      "description": "Auditor de código - análisis y calidad",
      "model": "review",
      "temperature": 0.1,
      "compact": false,
      "cavemanLevel": "lite",
      "permissions": {
        "read": "allow",
        "edit": "deny",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow"
      },
      "semantic": "Auditor",
      "bashRestriction": "read-only: cat, grep, ls, find, node --check, python -m py_compile"
    },
    "debug": {
      "description": "Detective de errores - diagnóstico raíz",
      "model": "coder",
      "temperature": 0.1,
      "compact": false,
      "cavemanLevel": "full",
      "permissions": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow"
      },
      "semantic": "Detective"
    },
    "docs": {
      "description": "Gestor de conocimiento - documentación y escritura en KB",
      "model": "fast",
      "temperature": 0.4,
      "compact": true,
      "cavemanLevel": "ultra",
      "permissions": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow"
      },
      "bashRestriction": "solo: mkdir -p, cat, echo, node search.js, node -e",
      "semantic": "Bibliotecario"
    },
    "decider": {
      "description": "Mediador de conflictos dominio vs implementación",
      "model": "base",
      "temperature": 0.4,
      "compact": false,
      "cavemanLevel": "none",
      "permissions": {
        "read": "allow",
        "edit": "allow",
        "bash": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow"
      },
      "activation": ["decidir", "conflicto", "arbitro"],
      "escalationThreshold": "Solo si el conflicto bloquea más de una tarea O involucra decisión irreversible",
      "semantic": "Arbitro"
    },
    "queue": {
      "description": "Gestor de pool de tareas - administra ejecución paralela con dependencias",
      "model": "base",
      "temperature": 0.2,
      "compact": false,
      "cavemanLevel": "lite",
      "permissions": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "allow"
      },
      "activation": ["queue", "pool", "gestionar"],
      "semantic": "QueueManager"
    },
    "launcher": {
      "description": "Lanzador de tareas en background - ejecuta @builder en paralelo real",
      "model": "coder",
      "temperature": 0.2,
      "compact": false,
      "cavemanLevel": "full",
      "permissions": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "allow"
      },
      "activation": ["launcher", "background", "parallel"],
      "semantic": "Launcher"
    },
    "calibrator": {
      "description": "Agente de calibracion - evalua rendimiento y detecta regresiones",
      "model": "review",
      "temperature": 0.1,
      "compact": false,
      "cavemanLevel": "lite",
      "permissions": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow"
      },
      "activation": ["calibrator", "eval", "metrics", "calibrar"],
      "semantic": "Calibrator"
    },
    "config-aora": {
      "description": "Asistente de configuración AORA - modelo, actualizaciones y estado",
      "model": "base",
      "temperature": 0.3,
      "compact": false,
      "cavemanLevel": "lite",
      "permissions": {
        "read": "allow",
        "edit": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow"
      },
      "activation": ["config-aora", "/config-aora", "setmodel", "configurar-modelo", "modelo"],
      "semantic": "ConfigAORA",
      "note": "Agente unificado: reemplaza setmodel.md. Maneja configuración de modelo Y actualizaciones."
    }
  },

  "workflow": {
    "compactMode": false,
    "parallelism": {
      "note": "Tareas independientes se ejecutan en paralelo via @launcher",
      "maxParallel": 3,
      "mechanism": "@launcher lanza sesiones opencode en background",
      "safeMode": true,
      "envVar": "AORA_PARALLEL",
      "backoffSeconds": 5,
      "maxRetries": 2
    },
    "phases": [
      {
        "phase": 0,
        "name": "ANALISIS",
        "agents": ["ultraworker"],
        "description": "Análisis rápido del contexto + consulta KB"
      },
      {
        "phase": 1,
        "name": "PLANIFICACION",
        "agents": ["planner"],
        "description": "Descomposición en tareas atómicas + consulta conocimiento previo"
      },
      {
        "phase": 2,
        "name": "IMPLEMENTACION",
        "agents": ["queue", "launcher", "builder"],
        "description": "@queue gestiona pool → @launcher lanza independientes en paralelo → @builder ejecuta dependientes",
        "parallelism": true
      },
{
        "phase": 3,
        "name": "REVISION",
        "agents": ["reviewer"],
        "description": "Validacion estructurada"
      },
      {
        "phase": 3.5,
        "name": "CALIBRACION",
        "agents": ["calibrator"],
        "description": "Registro de metricas post-tarea - actualiza metrics.json",
        "automatic": true
      },
      {
        "phase": 4,
        "name": "DOCUMENTACION",
        "agents": ["docs"],
        "description": "Registro en base de conocimiento — OBLIGATORIO, no saltar",
        "mandatory": true,
        "failurePolicy": "Si docs falla, ultraworker reintenta una vez antes de reportar al usuario. El trabajo implementado NO se revierte."
      }
    ],
    "decisionGate": {
      "enabled": true,
      "pausePhase": "PLANIFICACION",
      "registerIn": "DECISIONS.md",
      "escalateThreshold": "Conflicto bloquea >1 tarea o decisión irreversible"
    },
    "selfHealing": {
      "enabled": true,
      "maxAttempts": 3,
      "fallbackAgent": "debug",
      "metricsAgent": "calibrator"
    },
    "ci": {
      "enabled": true,
      "gateScript": "evals/ci-gate.sh",
      "thresholds": {
        "successRateMin": 0.8,
        "maxCorrections": 3,
        "maxRecentFailures": 2
      }
    }
  },

  "knowledge": {
    "files": {
      "knowledge": ".opencode/KNOWLEDGE.md",
      "decisions": ".opencode/DECISIONS.md",
      "kb": ".opencode/knowledge/KB.json"
    },
    "kbSchema": "array-root"
  },

  "opencodeTemplate": {
    "description": "Template para replicar permisos en opencode.json",
    "mergeStrategy": "smart",
    "permission": {
      "*": "allow",
      "bash": { "*": "allow", "rm -rf /*": "allow", "sudo rm *": "allow" },
      "external_directory": { "*": "allow" },
      "doom_loop": "ask"
    }
  }
}